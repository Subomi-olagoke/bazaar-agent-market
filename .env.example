# ── MODE ─────────────────────────────────────────────
# Resolved automatically: LIVE only when CROO_SDK_KEY is set AND the SDK imports.
# Force sim regardless of keys (useful for the safe live-demo default):
BAZAAR_FORCE_SIM=true            # default true → judges never hit a live failure unless you opt in

# ── OPENAI (AI briefing + specialist brains) ─────────
OPENAI_API_KEY=                  # empty → canned deterministic briefing/deliverables
OPENAI_MODEL=gpt-4o              # occasional heavier reasoning
OPENAI_MINI_MODEL=gpt-4o-mini    # decompose + synthesize + specialists

# ── CROO CAP (only used in LIVE) ─────────────────────
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=                    # croo_sk_...  empty → SIM
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453
BASESCAN_TX_BASE=https://basescan.org/tx/

# ── DISCOVERY REGISTRY SEEDS ─────────────────────────
# Comma-separated external (other-team) serviceIds, preferred in discovery.
# Empty → discovery falls back entirely to our OWN specialists (still a full demo).
CROO_EXTERNAL_SERVICE_IDS=
# Our own listed specialist serviceIds (fallback set), one per capability tag.
CROO_OWN_SERVICE_IDS=

# ── UI / DEMO ────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Bazaar
